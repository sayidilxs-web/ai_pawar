{
  "name": "nexus-ai-assistant",
  "version": "1.0.0",
  "description": "পাওয়ারফুল AI অ্যাসিস্ট্যান্ট - Bengali voice assistant with screen control",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "NEXUS AI",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-log": "^5.0.0",
    "robotjs": "^0.6.0"
  },
  "build": {
    "appId": "com.nexus.ai.assistant",
    "productName": "NEXUS AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "NEXUS-NEURAL-NETWORK/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NEXUS AI"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/**/*"
    ]
  }
}