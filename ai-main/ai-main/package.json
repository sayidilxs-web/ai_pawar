{
  "name": "nexus-ai-assistant",
  "version": "1.0.0",
  "description": "পাওয়ারফুল AI অ্যাসিস্ট্যান্ট - Bengali voice assistant with screen control",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "author": "NEXUS AI",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "@nut-tree/finder": "^1.0.2",
    "@nut-tree/nut-js": "^3.1.0",
    "electron-log": "^5.0.0",
    "screenshot-desktop": "^1.15.0",
    "robotjs": "^0.6.0"
  },
  "build": {
    "appId": "com.nexus.ai.assistant",
    "productName": "NEXUS AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}